<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.geometrium.joystick"
    android:versionCode="1"
    android:versionName="1.0">

    <!-- Указываем, что приложению нужен OpenGL ES 2.0 -->
    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <!-- 
      android:hasCode="false" — очень важно! 
      Это говорит системе, что у нас нет .dex (Java) файлов, только нативный код.
    -->
    <application
        android:label="Geometrium 2D"
        android:hasCode="false"
        android:icon="@android:drawable/sym_def_app_icon">

        <!-- Нативное окно Android, которое вызывает наш main.c -->
        <activity android:name="android.app.NativeActivity"
            android:label="Geometrium 2D"
            android:configChanges="orientation|keyboardHidden|screenSize|screenLayout"
            android:exported="true">
            
            <!-- 
              Имя библиотеки без "lib" и ".so". 
              В твоем скрипте сборки это libmain.so, поэтому пишем "main".
            -->
            <meta-data android:name="android.app.lib_name" android:value="main" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
